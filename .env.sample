# GLOBAL
NODE_ENV=development
MAX_CPU=1
FUNCTION_NAME=data-enrichment
PORT=3001
SIZE=150mb

# Comma-separated allowlist of trusted origins (protocol included)
CORS_ORIGINS=http://localhost:3000,http://10.10.80.37:3000

# POSTGRES
POSTGRES_CONTAINER_NAME=data-enrichment-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mydb

# Full DB URL used by ORM / DB client
CONFIGURATION_DATABASE_URL=postgresql://postgres:postgres@10.10.80.34:5432/uat

# REDIS
REDIS_CONTAINER_NAME=data-enrichment-redis
REDIS_HOST=10.10.80.37
REDIS_PORT=6379
REDIS_PASSWORD=redis-password
CACHE_TTL=86400

# NATS
NATS_CONTAINER_NAME=data-enrichment-nats
SERVER_URL=nats://10.10.80.34:4222
NATS_PORT=4222
NATS_HTTP_PORT=8222

STARTUP_TYPE=nats
PRODUCER_STREAM=config.notification.response
CONSUMER_STREAM=config.notification
STREAM_SUBJECT=config.notification

# ENCRYPTION
# 32-byte key required for AES-256 (example only)
ENCRYPTION_KEY=8fj29dkd82hs91kd93kd82hs91kd83ks
SALT_ROUNDS=9

# APM (Elastic APM)
APM_ACTIVE=true
APM_URL=http://10.10.80.17:8200
APM_SECRET_TOKEN=hello
APM_SERVICE_NAME=data-enrichment

# AUTH
TAZAMA_AUTH_URL=http://10.10.80.17:3020/v1/auth
AUTH_PUBLIC_KEY_PATH=public-key.pem
CERT_PATH_PUBLIC=public-key.pem

# SIDECAR
SIDECAR_HOST=10.10.80.17:5000

# LOGGING
LOGSTASH_LEVEL=info
